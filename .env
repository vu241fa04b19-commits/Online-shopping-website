# MongoDB Connection String
# Replace with your actual MongoDB connection string
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/shopgreen

# Option 2: MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shopgreen?retryWrites=true&w=majority

# JWT Secret Key
JWT_SECRET=shopgreen_secret_key_change_this_in_production

# Server Port
PORT=3001
